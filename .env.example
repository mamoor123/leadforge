# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadforge"

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379

# ─── Google APIs ─────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""
GOOGLE_PAGESPEED_API_KEY=""

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-string"

# ─── Email (for outreach) ───────────────────────────────────
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ─── AI (for pitch generation) ──────────────────────────────
OPENAI_API_KEY=""

# ─── Optional: Enhanced data sources ────────────────────────
HUNTER_API_KEY=""          # Email finding
SERP_API_KEY=""            # Google search results
WHOIS_API_KEY=""           # Domain expiry checks
BUILTWITH_API_KEY=""       # Tech stack detection

# ─── App ────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
PORT=4000
NODE_ENV="development"
